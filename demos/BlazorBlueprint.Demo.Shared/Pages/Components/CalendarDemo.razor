@page "/components/calendar"
<PageTitle>Calendar Component - Blazor Blueprint</PageTitle>

<div class="space-y-8 max-w-4xl">
    <div>
        <div class="space-y-3">
            <h1 class="text-4xl font-bold tracking-tight">Calendar Component</h1>
            <p class="text-xl text-muted-foreground">
                A date field component that allows users to select a date from a calendar view.
            </p>
        </div>
    </div>

    <!-- Basic Example -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Basic Example</h2>
            <p class="text-sm text-muted-foreground">
                A simple calendar for date selection. Supports keyboard interaction.
            </p>
        </div>
        <div class="border rounded-lg w-fit">
            <BbCalendar @bind-Selected="_selectedDate" />
        </div>
        <p class="text-sm text-muted-foreground">
            Selected: @(_selectedDate?.ToString("MMMM d, yyyy") ?? "None")
        </p>
        <CodeBlock Source="Components/Calendar/basic.txt" />
    </div>

    <!-- With Preselected Date -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Preselected Date</h2>
            <p class="text-sm text-muted-foreground">
                Calendar can start with a preselected date.
            </p>
        </div>
        <div class="border rounded-lg w-fit">
            <BbCalendar @bind-Selected="_preselectedDate" />
        </div>
        <p class="text-sm text-muted-foreground">
            Selected: @(_preselectedDate?.ToString("MMMM d, yyyy") ?? "None")
        </p>
        <CodeBlock Source="Components/Calendar/preselected.txt" />
    </div>

    <!-- Simple Header -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Simple Header</h2>
            <p class="text-sm text-muted-foreground">
                Hide the month/year dropdowns for a cleaner look. Navigation still works via arrow buttons and keyboard.
            </p>
        </div>
        <div class="border rounded-lg w-fit">
            <BbCalendar @bind-Selected="_simpleHeaderDate" ShowMonthYearDropdowns="false" />
        </div>
        <p class="text-sm text-muted-foreground">
            Selected: @(_simpleHeaderDate?.ToString("MMMM d, yyyy") ?? "None")
        </p>
        <CodeBlock Source="Components/Calendar/simple-header.txt" />
    </div>

    <!-- Date Constraints -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Date Constraints</h2>
            <p class="text-sm text-muted-foreground">
                Limit selectable dates with MinDate and MaxDate.
            </p>
        </div>
        <div class="border rounded-lg w-fit">
            <BbCalendar @bind-Selected="_constrainedDate"
                      MinDate="@_minDate"
                      MaxDate="@_maxDate" />
        </div>
        <p class="text-sm text-muted-foreground">
            Only dates between @_minDate.ToString("MMM d") and @_maxDate.ToString("MMM d, yyyy") are selectable.
        </p>
        <CodeBlock Source="Components/Calendar/constraints.txt" />
    </div>

    <!-- Disabled Dates -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Disabled Dates</h2>
            <p class="text-sm text-muted-foreground">
                Disable specific dates using a custom function (e.g., weekends).
            </p>
        </div>
        <div class="border rounded-lg w-fit">
            <BbCalendar @bind-Selected="_noWeekendsDate"
                      DisabledDates="@IsWeekend" />
        </div>
        <p class="text-sm text-muted-foreground">
            Weekends are disabled. Selected: @(_noWeekendsDate?.ToString("MMMM d, yyyy") ?? "None")
        </p>
        <CodeBlock Source="Components/Calendar/disabled-dates.txt" />
    </div>

    <!-- First Day of Week -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Week Start Day</h2>
            <p class="text-sm text-muted-foreground">
                Configure which day the week starts on.
            </p>
        </div>
        <div class="flex gap-8">
            <div>
                <p class="text-sm font-medium mb-2">Sunday (default)</p>
                <div class="border rounded-lg w-fit">
                    <BbCalendar @bind-Selected="_sundayStart" FirstDayOfWeek="DayOfWeek.Sunday" />
                </div>
            </div>
            <div>
                <p class="text-sm font-medium mb-2">Monday</p>
                <div class="border rounded-lg w-fit">
                    <BbCalendar @bind-Selected="_mondayStart" FirstDayOfWeek="DayOfWeek.Monday" />
                </div>
            </div>
        </div>
        <CodeBlock Source="Components/Calendar/week-start.txt" />
    </div>

    <!-- Auto Focus -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Auto Focus</h2>
            <p class="text-sm text-muted-foreground">
                Set <code>AutoFocus</code> to move keyboard focus to the active day as soon as the calendar
                renders, so arrow keys work immediately without clicking first. Ideal when the calendar
                appears in a popover or dialog (the date picker uses this internally). Leave it off for
                always-visible inline calendars to avoid stealing focus on page load.
            </p>
        </div>
        <div class="space-y-3">
            <BbButton Variant="ButtonVariant.Outline" OnClick="@(() => _showAutoFocusCalendar = !_showAutoFocusCalendar)">
                @(_showAutoFocusCalendar ? "Hide calendar" : "Show calendar")
            </BbButton>
            @if (_showAutoFocusCalendar)
            {
                <div class="border rounded-lg w-fit">
                    <BbCalendar @bind-Selected="_autoFocusDate" AutoFocus="true" />
                </div>
                <p class="text-sm text-muted-foreground">
                    Focus lands on the active day &mdash; use the arrow keys straight away. Selected:
                    @(_autoFocusDate?.ToString("MMMM d, yyyy") ?? "None")
                </p>
            }
        </div>
        <CodeBlock Source="Components/Calendar/auto-focus.txt" />
    </div>

    <AccessibilityList>
        <AriaAttributes>
            <AccessibilityItem>Uses role="grid" for the calendar table</AccessibilityItem>
            <AccessibilityItem>Day cells use aria-selected for the current selection</AccessibilityItem>
            <AccessibilityItem>Disabled dates are marked with aria-disabled</AccessibilityItem>
            <AccessibilityItem>Navigation buttons have descriptive aria-label attributes</AccessibilityItem>
        </AriaAttributes>
        <KeyboardNavigation>
            <KeyboardShortcutItem Description="Navigate days">
                <BbKbd>Arrow Keys</BbKbd>
            </KeyboardShortcutItem>
            <KeyboardShortcutItem Description="Select date">
                <BbKbd>Enter</BbKbd>
            </KeyboardShortcutItem>
            <KeyboardShortcutItem Description="First day of month">
                <BbKbd>Home</BbKbd>
            </KeyboardShortcutItem>
            <KeyboardShortcutItem Description="Last day of month">
                <BbKbd>End</BbKbd>
            </KeyboardShortcutItem>
            <KeyboardShortcutItem Description="Previous / Next month">
                <BbKbd>Page Up</BbKbd> / <BbKbd>Page Down</BbKbd>
            </KeyboardShortcutItem>
            <KeyboardShortcutItem Description="Previous / Next year">
                <BbKbd>Shift+Page Up</BbKbd> / <BbKbd>Shift+Page Down</BbKbd>
            </KeyboardShortcutItem>
        </KeyboardNavigation>
    </AccessibilityList>

    <!-- API Reference -->
    <section class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">API Reference</h2>
            <p class="text-muted-foreground">Component properties and parameters.</p>
        </div>
        <div class="space-y-4">
            <ApiReference ComponentName="Calendar">
                <ApiParameter Name="Selected" Type="DateTime?" Default="null">
                    The currently selected date. Use @@bind-Selected for two-way binding.
                </ApiParameter>
                <ApiParameter Name="MinDate" Type="DateTime?" Default="null">
                    The minimum selectable date. Dates before this are disabled.
                </ApiParameter>
                <ApiParameter Name="MaxDate" Type="DateTime?" Default="null">
                    The maximum selectable date. Dates after this are disabled.
                </ApiParameter>
                <ApiParameter Name="DisabledDates" Type="Func&lt;DateTime, bool&gt;?" Default="null">
                    Function to determine if a date should be disabled.
                </ApiParameter>
                <ApiParameter Name="FirstDayOfWeek" Type="DayOfWeek" Default="DayOfWeek.Sunday">
                    Which day the week starts on.
                </ApiParameter>
                <ApiParameter Name="ShowMonthYearDropdowns" Type="bool" Default="true">
                    Whether to show month/year dropdown selectors. When false, displays a simple text header.
                </ApiParameter>
                <ApiParameter Name="AutoFocus" Type="bool" Default="false">
                    Whether to move keyboard focus to the active day when the calendar first renders, so arrow-key navigation works immediately. Useful for calendars shown in a popover or dialog.
                </ApiParameter>
                <ApiParameter Name="OnSelect" Type="EventCallback&lt;DateTime&gt;">
                    Callback when a date is selected.
                </ApiParameter>
            </ApiReference>
        </div>
    </section>

    <LocalizationSection
        Description="Calendar navigation labels and culture-aware month/day names are configurable."
        Labels="@(new LocalizationSection.LabelInfo[]
        {
            new("GoToPreviousMonth", "Go to previous month", "Aria label for the previous month button"),
            new("GoToNextMonth", "Go to next month", "Aria label for the next month button"),
        })"
        CultureAware="true"
        CultureDescription="Month names, day names, and the first day of the week are automatically derived from CultureInfo.CurrentCulture. Override with the MonthNames, DayNames, and FirstDayOfWeek parameters."
        CodeExample="@(@"services.AddBlazorBlueprintComponents(opts =>
{
    opts.Calendar.GoToPreviousMonth = ""Vorheriger Monat"";
    opts.Calendar.GoToNextMonth = ""Nächster Monat"";
});")" />
</div>

@code {
    private DateTime? _selectedDate;
    private DateTime? _preselectedDate = DateTime.Today;
    private DateTime? _simpleHeaderDate;
    private DateTime? _constrainedDate;
    private DateTime? _noWeekendsDate;
    private DateTime? _sundayStart;
    private DateTime? _mondayStart;
    private DateTime? _autoFocusDate;
    private bool _showAutoFocusCalendar;

    private DateTime _minDate = DateTime.Today;
    private DateTime _maxDate = DateTime.Today.AddDays(30);

    private bool IsWeekend(DateTime date)
    {
        return date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
    }
}
