    private async Task HandleUserSearch(string query)
    {
        userSearchCts?.Cancel();
        var cts = userSearchCts = new CancellationTokenSource();

        asyncCompIsLoading = true;
        StateHasChanged();

        try
        {
            await Task.Delay(300, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(query))
        {
            var defaults = allUsers[0..5];

            // Ensure the selected user is visible so the user can see/deselect it,
            // even when it falls outside the default top-N slice.
            if (asyncCompSelectedUser is not null
                && !defaults.Any(u => u.Id == asyncCompSelectedUser))
            {
                var selected = allUsers.FirstOrDefault(u => u.Id == asyncCompSelectedUser);
                if (selected is not null)
                {
                    defaults = [selected, .. defaults];
                }
            }

            asyncCompUsers = defaults;
        }
        else
        {
            asyncCompUsers = allUsers
                .Where(u => u.Name.Contains(query, StringComparison.OrdinalIgnoreCase)
                         || u.Role.Contains(query, StringComparison.OrdinalIgnoreCase))
                .ToArray();
        }

        asyncCompIsLoading = false;
        StateHasChanged();
    }

    private string GetAsyncCompUserName(string? id) =>
        id is not null ? allUsers.FirstOrDefault(u => u.Id == id)?.Name ?? "(none)" : "(none)";

