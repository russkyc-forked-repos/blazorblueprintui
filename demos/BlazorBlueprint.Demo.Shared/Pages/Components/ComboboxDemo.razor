        searchCts?.Cancel();
        var cts = searchCts = new CancellationTokenSource();

        asyncIsLoading = true;
        StateHasChanged();

        try
        {
            // Simulate API call delay
            await Task.Delay(300, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(query))
        {
            var defaults = allCities[0..5];

            // Ensure the selected city is visible so the user can see/deselect it,
            // even when it falls outside the default top-N slice.
            if (asyncSelectedCity is not null
                && !defaults.Any(c => c.Value == asyncSelectedCity))
            {
                var selected = allCities.FirstOrDefault(c => c.Value == asyncSelectedCity);
                if (selected is not null)
                {
                    defaults = [selected, .. defaults];
                }
            }

            asyncCities = defaults;
        }
        else
        {
            asyncCities = allCities
                .Where(c => c.Text.Contains(query, StringComparison.OrdinalIgnoreCase))
                .ToArray();
        }

        asyncIsLoading = false;
        StateHasChanged();
    }

    // Async compositional mode example
    private string? asyncCompSelectedUser;
    private UserInfo[] asyncCompUsers = allUsers[0..5];
    private bool asyncCompIsLoading;
    private CancellationTokenSource? userSearchCts;

