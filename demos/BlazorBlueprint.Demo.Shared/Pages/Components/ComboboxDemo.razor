    private const int ProductPageSize = 20;

    private static readonly SelectOption<string>[] allProducts = GenerateProducts();

    private static SelectOption<string>[] GenerateProducts()
    {
        var categories = new[] { "Widget", "Gadget", "Module", "Adapter", "Sensor", "Controller", "Display", "Connector", "Filter", "Driver" };
        var materials = new[] { "Steel", "Carbon", "Titanium", "Copper", "Ceramic", "Polymer", "Silicon", "Aluminum", "Glass", "Platinum" };
        var products = new List<SelectOption<string>>();

        for (int i = 1; i <= 200; i++)
        {
            var category = categories[(i - 1) % categories.Length];
            var material = materials[(i - 1) / categories.Length % materials.Length];
            var id = $"prod-{i:D4}";
            var name = $"{material} {category} {i:D4}";
            products.Add(new SelectOption<string>(id, name));
        }

        return products.ToArray();
    }

    protected override void OnInitialized()
    {
        // Load initial page for Options mode demo
        infiniteScrollFilteredTotal = allProducts.Length;
        infiniteScrollProducts = allProducts.Take(ProductPageSize).ToArray();

        // Load initial page for compositional mode demo
        InitCountryScroll();
    }

    private async Task HandleProductSearch(string query)
    {
        productSearchCts?.Cancel();
        var cts = productSearchCts = new CancellationTokenSource();

        infiniteScrollIsLoading = true;
        infiniteScrollCurrentQuery = query;
        StateHasChanged();

        try
        {
            await Task.Delay(200, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        var filtered = GetFilteredProducts(query);
        infiniteScrollFilteredTotal = filtered.Length;
        infiniteScrollProducts = filtered.Take(ProductPageSize).ToArray();
        infiniteScrollIsLoading = false;
        StateHasChanged();
    }

    private async Task HandleLoadMoreProducts()
    {
        infiniteScrollIsLoading = true;
        StateHasChanged();

        // Simulate network latency
        await Task.Delay(300);

        var filtered = GetFilteredProducts(infiniteScrollCurrentQuery);
        infiniteScrollFilteredTotal = filtered.Length;
        var nextCount = infiniteScrollProducts.Length + ProductPageSize;
        infiniteScrollProducts = filtered.Take(nextCount).ToArray();
        infiniteScrollIsLoading = false;
        StateHasChanged();
    }

    private SelectOption<string>[] GetFilteredProducts(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return allProducts;
        }

        return allProducts
            .Where(p => p.Text.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

