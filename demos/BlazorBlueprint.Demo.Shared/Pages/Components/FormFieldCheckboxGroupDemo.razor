@page "/components/form-field-checkbox-group"

<PageTitle>FormFieldCheckboxGroup Component - Blazor Blueprint</PageTitle>

<div class="space-y-8 max-w-4xl">
    <div>
        <div class="space-y-3">
            <h1 class="text-4xl font-bold tracking-tight">FormFieldCheckboxGroup</h1>
            <p class="text-xl text-muted-foreground">
                A form field wrapper for CheckboxGroup with built-in label, helper text, and error messages.
            </p>
        </div>
    </div>

    <!-- Basic Example -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Basic Usage</h2>
            <p class="text-sm text-muted-foreground">
                A checkbox group with a label and helper text.
            </p>
        </div>
        <div class="max-w-md">
            <BbFormFieldCheckboxGroup TValue="string"
                                     @bind-Values="_selectedFruits"
                                     Label="Favorite fruits"
                                     HelperText="Select all that apply.">
                <BbCheckboxGroupItem Value="@("apple")" Label="Apple" />
                <BbCheckboxGroupItem Value="@("banana")" Label="Banana" />
                <BbCheckboxGroupItem Value="@("cherry")" Label="Cherry" />
                <BbCheckboxGroupItem Value="@("grape")" Label="Grape" />
            </BbFormFieldCheckboxGroup>
        </div>
        <div class="rounded-lg border p-4 bg-muted/50">
            <p class="text-sm font-medium mb-1">Selected:</p>
            <p class="text-sm font-mono">@((_selectedFruits.Any()) ? string.Join(", ", _selectedFruits) : "(none)")</p>
        </div>
        <CodeBlock Source="Components/FormFieldCheckboxGroup/basic.txt" />
    </div>

    <!-- With Select All -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">With Select All</h2>
            <p class="text-sm text-muted-foreground">
                Enable <code class="text-xs bg-muted px-1 py-0.5 rounded">ShowSelectAll</code> to add a toggle-all checkbox.
            </p>
        </div>
        <div class="max-w-md">
            <BbFormFieldCheckboxGroup TValue="string"
                                     @bind-Values="_selectedPermissions"
                                     Label="Permissions"
                                     HelperText="Grant access to these features."
                                     ShowSelectAll="true"
                                     SelectAllLabel="Grant all">
                <BbCheckboxGroupItem Value="@("read")" Label="Read" />
                <BbCheckboxGroupItem Value="@("write")" Label="Write" />
                <BbCheckboxGroupItem Value="@("delete")" Label="Delete" />
                <BbCheckboxGroupItem Value="@("admin")" Label="Admin" />
            </BbFormFieldCheckboxGroup>
        </div>
        <div class="rounded-lg border p-4 bg-muted/50">
            <p class="text-sm font-medium mb-1">Selected:</p>
            <p class="text-sm font-mono">@((_selectedPermissions.Any()) ? string.Join(", ", _selectedPermissions) : "(none)")</p>
        </div>
        <CodeBlock Source="Components/FormFieldCheckboxGroup/select-all.txt" />
    </div>

    <!-- Disabled -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Disabled</h2>
            <p class="text-sm text-muted-foreground">A disabled checkbox group form field.</p>
        </div>
        <div class="max-w-md">
            <BbFormFieldCheckboxGroup TValue="string"
                                     Values="@(new[] { "email" })"
                                     Label="Notification channels"
                                     HelperText="Managed by your administrator."
                                     Disabled="true">
                <BbCheckboxGroupItem Value="@("email")" Label="Email" />
                <BbCheckboxGroupItem Value="@("sms")" Label="SMS" />
                <BbCheckboxGroupItem Value="@("push")" Label="Push" />
            </BbFormFieldCheckboxGroup>
        </div>
        <CodeBlock Source="Components/FormFieldCheckboxGroup/disabled.txt" />
    </div>

    <!-- Validation with ErrorText -->
    <div class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">Validation with ErrorText</h2>
            <p class="text-sm text-muted-foreground">
                CheckboxGroup doesn't support <code class="text-xs bg-muted px-1 py-0.5 rounded">EditForm</code> directly.
                Use <code class="text-xs bg-muted px-1 py-0.5 rounded">ErrorText</code> for manual validation.
            </p>
        </div>
        <div class="max-w-md">
            <BbFormFieldCheckboxGroup TValue="string"
                                     Values="_validatedTopics"
                                     ValuesChanged="OnValidatedTopicsChanged"
                                     Label="Topics of interest"
                                     HelperText="Select at least one topic."
                                     ErrorText="@_topicsError">
                <BbCheckboxGroupItem Value="@("tech")" Label="Technology" />
                <BbCheckboxGroupItem Value="@("science")" Label="Science" />
                <BbCheckboxGroupItem Value="@("art")" Label="Art" />
                <BbCheckboxGroupItem Value="@("sports")" Label="Sports" />
            </BbFormFieldCheckboxGroup>
            <div class="mt-3">
                <BbButton OnClick="ValidateTopics">Submit</BbButton>
            </div>
            @if (_topicsSubmitted)
            {
                <div class="mt-4 rounded-lg border border-green-200 bg-green-50 dark:bg-green-950 dark:border-green-800 p-4">
                    <p class="text-sm font-medium text-green-800 dark:text-green-200">
                        Submitted: @string.Join(", ", _validatedTopics)
                    </p>
                </div>
            }
        </div>
        <CodeBlock Source="Components/FormFieldCheckboxGroup/validation.txt" />
    </div>

    <AccessibilityList>
        <AriaAttributes>
            <AccessibilityItem>Label visually associated with the checkbox group</AccessibilityItem>
            <AccessibilityItem>Group rendered with role="group"</AccessibilityItem>
            <AccessibilityItem>Description linked via aria-describedby</AccessibilityItem>
        </AriaAttributes>
    </AccessibilityList>

    <!-- API Reference -->
    <section class="space-y-4">
        <div class="space-y-2">
            <h2 class="text-2xl font-semibold">API Reference</h2>
            <p class="text-muted-foreground">Component properties and parameters.</p>
        </div>
        <div class="space-y-4">
            <ApiReference ComponentName="FormFieldCheckboxGroup&lt;TValue&gt;">
                <ApiParameter Name="Label" Type="string?" Default="null">The label text.</ApiParameter>
                <ApiParameter Name="HelperText" Type="string?" Default="null">Helper text below the group.</ApiParameter>
                <ApiParameter Name="ErrorText" Type="string?" Default="null">Manual error text override.</ApiParameter>
                <ApiParameter Name="Values" Type="IReadOnlyCollection&lt;TValue&gt;" Default="[]">The selected values. Use @@bind-Values.</ApiParameter>
                <ApiParameter Name="ValuesChanged" Type="EventCallback&lt;IReadOnlyCollection&lt;TValue&gt;&gt;">Callback when values change.</ApiParameter>
                <ApiParameter Name="ShowSelectAll" Type="bool" Default="false">Show a "Select all" checkbox.</ApiParameter>
                <ApiParameter Name="SelectAllLabel" Type="string" Default="&quot;Select all&quot;">Label for the select-all checkbox.</ApiParameter>
                <ApiParameter Name="Disabled" Type="bool" Default="false">Whether all items are disabled.</ApiParameter>
                <ApiParameter Name="ChildContent" Type="RenderFragment?" Default="null">CheckboxGroupItem components.</ApiParameter>
                <ApiParameter Name="InputClass" Type="string?" Default="null">CSS classes for the inner group.</ApiParameter>
            </ApiReference>
        </div>
    </section>
</div>

@code {
    private IReadOnlyCollection<string> _selectedFruits = Array.Empty<string>();
    private IReadOnlyCollection<string> _selectedPermissions = Array.Empty<string>();
    private IReadOnlyCollection<string> _validatedTopics = Array.Empty<string>();
    private string? _topicsError;
    private bool _topicsSubmitted;

    private void OnValidatedTopicsChanged(IReadOnlyCollection<string> values)
    {
        _validatedTopics = values;
        _topicsError = null;
        _topicsSubmitted = false;
    }

    private void ValidateTopics()
    {
        _topicsSubmitted = false;

        if (!_validatedTopics.Any())
        {
            _topicsError = "Please select at least one topic.";
            return;
        }

        _topicsError = null;
        _topicsSubmitted = true;
    }
}
