    private void InitCountryScroll()
    {
        _countryScrollFilteredTotal = _allCountryData.Length;
        _countryScrollVisible = _allCountryData.Take(CountryPageSize).ToArray();
    }

    private async Task HandleCountrySearch(string query)
    {
        _countrySearchCts?.Cancel();
        var cts = _countrySearchCts = new CancellationTokenSource();

        _countryScrollIsLoading = true;
        _countryScrollCurrentQuery = query;
        StateHasChanged();

        try
        {
            await Task.Delay(200, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        var filtered = GetFilteredCountries(query);
        _countryScrollFilteredTotal = filtered.Length;
        _countryScrollVisible = filtered.Take(CountryPageSize).ToArray();
        _countryScrollIsLoading = false;
        StateHasChanged();
    }

    private async Task HandleLoadMoreCountries()
    {
        _countryScrollIsLoading = true;
        StateHasChanged();

        await Task.Delay(300);

        var filtered = GetFilteredCountries(_countryScrollCurrentQuery);
        _countryScrollFilteredTotal = filtered.Length;
        var nextCount = _countryScrollVisible.Length + CountryPageSize;
        _countryScrollVisible = filtered.Take(nextCount).ToArray();
        _countryScrollIsLoading = false;
        StateHasChanged();
    }

    private CountryInfo[] GetFilteredCountries(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return _allCountryData;
        }

        return _allCountryData
            .Where(c => c.Name.Contains(query, StringComparison.OrdinalIgnoreCase)
                     || c.Code.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

