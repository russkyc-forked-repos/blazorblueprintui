    private string _ffmsCurrentQuery = string.Empty;

    private void InitFfmsScroll()
    {
        _ffmsScrollCountries = _allFfmsCountries.Take(FfmsPageSize).ToArray();
    }

    private SelectOption<string>[] GetFilteredFfmsCountries(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return _allFfmsCountries;
        }

        return _allFfmsCountries
            .Where(c => c.Text.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

    private async Task HandleFfmsSearch(string query)
    {
        _ffmsScrollIsLoading = true;
        _ffmsCurrentQuery = query;
        StateHasChanged();

        await Task.Delay(200);

        var filtered = GetFilteredFfmsCountries(query);
        _ffmsScrollCountries = filtered.Take(FfmsPageSize).ToArray();
        _ffmsScrollIsLoading = false;
        StateHasChanged();
    }

    private async Task HandleFfmsLoadMore()
    {
        _ffmsScrollIsLoading = true;
        StateHasChanged();

        await Task.Delay(300);

        var filtered = GetFilteredFfmsCountries(_ffmsCurrentQuery);
        var nextCount = _ffmsScrollCountries.Length + FfmsPageSize;
        _ffmsScrollCountries = filtered.Take(nextCount).ToArray();
        _ffmsScrollIsLoading = false;
        StateHasChanged();
    }

