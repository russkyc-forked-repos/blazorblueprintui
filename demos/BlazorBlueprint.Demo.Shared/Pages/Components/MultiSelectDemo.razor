    private void InitMsScroll()
    {
        _msScrollCountries = _allMsCountries.Take(MsPageSize).ToArray();
    }

    private SelectOption<string>[] GetFilteredMsCountries(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return _allMsCountries;
        }

        return _allMsCountries
            .Where(c => c.Text.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

    private async Task HandleMsSearch(string query)
    {
        _msScrollIsLoading = true;
        _msScrollCurrentQuery = query;
        StateHasChanged();

        await Task.Delay(200);

        var filtered = GetFilteredMsCountries(query);
        _msScrollCountries = filtered.Take(MsPageSize).ToArray();
        _msScrollIsLoading = false;
        StateHasChanged();
    }

    private async Task HandleMsLoadMore()
    {
        _msScrollIsLoading = true;
        StateHasChanged();
        await Task.Delay(300);
        var filtered = GetFilteredMsCountries(_msScrollCurrentQuery);
        var nextCount = _msScrollCountries.Length + MsPageSize;
        _msScrollCountries = filtered.Take(nextCount).ToArray();
        _msScrollIsLoading = false;
        StateHasChanged();
    }

