@namespace BlazorBlueprint.Icons.FontAwesome.Components

@if (IconEntry is not null)
{
    <svg
        width="@ComputedSize"
        height="@ComputedHeight"
        viewBox="@ViewBox"
        fill="@Color"
        class="@CssClass"
        role="img"
        aria-label="@AriaLabel"
        @attributes="AdditionalAttributes">
        @((MarkupString)SvgBody)
    </svg>
}
else
{
    @* Fallback for missing icons *@
    <span class="text-destructive" role="alert" aria-label="Icon not found: @Name (@Variant)">⚠️</span>
}
